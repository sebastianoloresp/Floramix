@page "/shop-settings"
@inject IShopService ShopService
@inject ShopStateService ShopState

<PageTitle>Settings - FloraMix</PageTitle>

<div class="fs-page">
    <header class="fs-header">
        <h1>Settings</h1>
        <p class="fs-subtitle">@(shop?.Name ?? "Shop") · Shop Portal</p>
    </header>

    @if (shop is null)
    {
        <p class="fs-loading">Loading...</p>
    }
    else
    {
        <div class="fs-grid">
            <div class="fs-card">
                <div class="fs-card-header">
                    <span class="fs-card-icon">@((MarkupString)Icon.Gear)</span>
                    <h2>Shop Profile</h2>
                </div>

                <div class="fs-profile-row">
                    <div class="fs-avatar">@GetInitials(shop.Name)</div>
                    <div>
                        <div class="fs-profile-name">@(string.IsNullOrWhiteSpace(shop.Name) ? "Unnamed shop" : shop.Name)</div>
                        <div class="fs-profile-sub">@(string.IsNullOrWhiteSpace(shop.Address) ? "No address set" : shop.Address)</div>
                    </div>
                </div>

                <div class="fs-field">
                    <label>Shop Name</label>
                    <input class="fs-input" @bind="shop.Name" />
                </div>

                <div class="fs-field">
                    <label>Email</label>
                    <input class="fs-input" @bind="shop.Email" placeholder="hello@yourshop.co.uk" />
                </div>

                <div class="fs-field">
                    <label>Phone</label>
                    <input class="fs-input" @bind="shop.Phone" placeholder="+44 20 0000 0000" />
                </div>

                <div class="fs-field">
                    <label>Address</label>
                    <input class="fs-input" @bind="shop.Address" />
                </div>

                <button class="fs-save-btn" @onclick="Save">Save Changes</button>

                @if (savedMessage is not null)
                {
                    <p class="fs-saved">
                        <span class="fs-saved-icon">@((MarkupString)Icon.Check)</span>
                        @savedMessage
                    </p>
                }
            </div>

            <div class="fs-side-column">
                <div class="fs-card">
                    <div class="fs-card-header">
                        <span class="fs-card-icon">@((MarkupString)Icon.Clock)</span>
                        <h2>Business Hours</h2>
                    </div>
                    <ul class="fs-hours-list">
                        @foreach (var day in businessHours)
                        {
                            <li>
                                <span class="fs-hours-day">
                                    <label class="fs-hours-checkbox">
                                        <input type="checkbox" checked="@day.IsOpen" @onchange="e => day.IsOpen = (bool)e.Value!" />
                                        <span class="fs-hours-dot @(day.IsOpen ? "fs-open" : "fs-closed")"></span>
                                    </label>
                                    @day.Day
                                </span>
                                @if (day.IsOpen)
                                {
                                    <input class="fs-hours-input" @bind="day.Time" placeholder="9:00 AM – 6:00 PM" />
                                }
                                else
                                {
                                    <span class="fs-hours-time">Closed</span>
                                }
                            </li>
                        }
                    </ul>
                </div>

                <div class="fs-card">
                    <div class="fs-card-header">
                        <span class="fs-card-icon">@((MarkupString)Icon.Bell)</span>
                        <h2>Notification Preferences</h2>
                    </div>
                    <ul class="fs-notif-list">
                        <li>
                            <span>New order alerts</span>
                            <label class="fs-toggle">
                                <input type="checkbox" checked="@shop.NotifyNewOrders" @onchange="e => shop.NotifyNewOrders = (bool)e.Value!" />
                                <span class="fs-toggle-slider"></span>
                            </label>
                        </li>
                        <li>
                            <span>Customer messages</span>
                            <label class="fs-toggle">
                                <input type="checkbox" checked="@shop.NotifyCustomerMessages" @onchange="e => shop.NotifyCustomerMessages = (bool)e.Value!" />
                                <span class="fs-toggle-slider"></span>
                            </label>
                        </li>
                        <li>
                            <span>Low stock warnings</span>
                            <label class="fs-toggle">
                                <input type="checkbox" checked="@shop.NotifyLowStock" @onchange="e => shop.NotifyLowStock = (bool)e.Value!" />
                                <span class="fs-toggle-slider"></span>
                            </label>
                        </li>
                        <li>
                            <span>Daily revenue summary</span>
                            <label class="fs-toggle">
                                <input type="checkbox" checked="@shop.NotifyDailyRevenue" @onchange="e => shop.NotifyDailyRevenue = (bool)e.Value!" />
                                <span class="fs-toggle-slider"></span>
                            </label>
                        </li>
                        <li>
                            <span>Weekly analytics report</span>
                            <label class="fs-toggle">
                                <input type="checkbox" checked="@shop.NotifyWeeklyAnalytics" @onchange="e => shop.NotifyWeeklyAnalytics = (bool)e.Value!" />
                                <span class="fs-toggle-slider"></span>
                            </label>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    }
</div>

@code {
    Shop? shop;
    string? savedMessage;
    int shopId = 1; // TODO: replace with logged-in owner's shop

    class DayHours
    {
        public string Day { get; set; } = "";
        public string Time { get; set; } = "";
        public bool IsOpen { get; set; }

        public DayHours(string day, string time, bool isOpen)
        {
            Day = day;
            Time = time;
            IsOpen = isOpen;
        }
    }

    List<DayHours> businessHours = new()
    {
        new("Monday", "9:00 AM – 6:00 PM", true),
        new("Tuesday", "9:00 AM – 6:00 PM", true),
        new("Wednesday", "9:00 AM – 6:00 PM", true),
        new("Thursday", "9:00 AM – 6:00 PM", true),
        new("Friday", "9:00 AM – 6:00 PM", true),
        new("Saturday", "9:00 AM – 4:00 PM", true),
        new("Sunday", "Closed", false),
    };

    protected override async Task OnInitializedAsync()
    {
        shop = await ShopService.GetShopAsync(shopId);
        if (shop is null)
        {
            shop = new Shop { Id = shopId, Name = "My Flower Shop" };
        }

        if (!string.IsNullOrWhiteSpace(shop.BusinessHoursJson))
        {
            try
            {
                var saved = System.Text.Json.JsonSerializer.Deserialize<List<DayHours>>(shop.BusinessHoursJson);
                if (saved is { Count: > 0 })
                {
                    businessHours = saved;
                }
            }
            catch
            {
                // Fall back to the default hours above if the saved JSON is malformed.
            }
        }
    }

    async Task Save()
    {
        if (shop is null) return;

        shop.BusinessHoursJson = System.Text.Json.JsonSerializer.Serialize(businessHours);

        shop = await ShopService.SaveShopAsync(shop);
        ShopState.NotifyShopChanged();
        savedMessage = "Saved!";
    }

    static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant(),
            _ => $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant()
        };
    }

    static class Icon
    {
        public const string Gear = "<svg width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><circle cx='12' cy='12' r='3'/><path d='M19.4 15a1.7 1.7 0 0 0 .34 1.87l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.7 1.7 0 0 0-1.87-.34 1.7 1.7 0 0 0-1 1.55V21a2 2 0 0 1-4 0v-.09A1.7 1.7 0 0 0 9 19.4a1.7 1.7 0 0 0-1.87.34l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.7 1.7 0 0 0 4.6 15a1.7 1.7 0 0 0-1.55-1H3a2 2 0 0 1 0-4h.09A1.7 1.7 0 0 0 4.6 9a1.7 1.7 0 0 0-.34-1.87l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.7 1.7 0 0 0 9 4.6a1.7 1.7 0 0 0 1-1.55V3a2 2 0 0 1 4 0v.09a1.7 1.7 0 0 0 1 1.55 1.7 1.7 0 0 0 1.87-.34l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.7 1.7 0 0 0 19.4 9a1.7 1.7 0 0 0 1.55 1H21a2 2 0 0 1 0 4h-.09a1.7 1.7 0 0 0-1.51 1Z'/></svg>";
        public const string Check = "<svg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='3'><path d='M20 6 9 17l-5-5'/></svg>";
        public const string Clock = "<svg width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><circle cx='12' cy='12' r='9'/><path d='M12 7v5l3 3'/></svg>";
        public const string Bell = "<svg width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M18 8a6 6 0 1 0-12 0c0 7-3 9-3 9h18s-3-2-3-9Z'/><path d='M13.73 21a2 2 0 0 1-3.46 0'/></svg>";
    }
}

<style>
    /* Prefixed "fs-" (FloraMix Settings) to avoid clashing with classes used
           on other pages. Assumes the cream page background and fonts
           (Playfair Display / Open Sans) are already provided by your shared layout. */

    .fs-page {
        font-family: 'Open Sans', 'Segoe UI', sans-serif;
        color: #2E2B3D;
    }

        .fs-page h1, .fs-page h2 {
            font-family: 'Playfair Display', Georgia, serif;
            margin: 0;
        }

    .fs-header {
        margin-bottom: 22px;
    }

    .fs-subtitle {
        margin: 4px 0 0;
        color: #8B8680;
        font-size: 13px;
    }

    .fs-loading {
        color: #8B8680;
    }

    .fs-grid {
        display: grid;
        grid-template-columns: 1.3fr 1fr;
        gap: 18px;
        align-items: start;
    }

    .fs-side-column {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .fs-card {
        background: #FFFFFF;
        border-radius: 18px;
        padding: 24px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.04);
    }

    .fs-card-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 18px;
    }

    .fs-card-icon {
        color: #D9628A;
        display: flex;
    }

    .fs-card-header h2 {
        font-size: 17px;
    }

    .fs-profile-row {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 22px;
        padding-bottom: 18px;
        border-bottom: 1px solid #F0EBE5;
    }

    .fs-avatar {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 15px;
        color: #FFFFFF;
        background: linear-gradient(135deg, #E7A9A0, #C98CA6);
    }

    .fs-profile-name {
        font-weight: 600;
        font-size: 14px;
    }

    .fs-profile-sub {
        font-size: 12px;
        color: #8B8680;
        margin-top: 2px;
    }

    .fs-linklike {
        border: none;
        background: none;
        padding: 4px 0 0;
        color: #D9628A;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        font-family: inherit;
    }

    .fs-field {
        margin-bottom: 16px;
    }

        .fs-field label {
            display: block;
            font-size: 12px;
            color: #8B8680;
            margin-bottom: 6px;
        }

    .fs-input {
        width: 100%;
        box-sizing: border-box;
        background: #F1ECE6;
        border: 1px solid transparent;
        border-radius: 12px;
        padding: 12px 14px;
        font-size: 14px;
        color: #2E2B3D;
        font-family: inherit;
        outline: none;
        transition: border-color .15s ease, background .15s ease;
    }

        .fs-input:focus {
            background: #FFFFFF;
            border-color: #F2A7BD;
        }

    .fs-save-btn {
        width: 100%;
        border: none;
        border-radius: 24px;
        padding: 12px 18px;
        background: #F2A0B5;
        color: #FFFFFF;
        font-size: 14px;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        margin-top: 4px;
        transition: background .15s ease;
    }

        .fs-save-btn:hover {
            background: #ED8AA5;
        }

    .fs-saved {
        display: flex;
        align-items: center;
        gap: 6px;
        color: #3F9160;
        font-size: 13px;
        font-weight: 600;
        margin: 14px 0 0;
    }

    .fs-saved-icon {
        display: flex;
        background: #E9F5EC;
        border-radius: 50%;
        padding: 3px;
        color: #3F9160;
    }

    .fs-hours-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

        .fs-hours-list li {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 13px;
        }

    .fs-hours-day {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .fs-hours-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        flex-shrink: 0;
    }

        .fs-hours-dot.fs-open {
            background: #4CAF6D;
        }

        .fs-hours-dot.fs-closed {
            background: #C8C3BC;
        }

    .fs-hours-checkbox {
        display: inline-flex;
        align-items: center;
        cursor: pointer;
    }

        .fs-hours-checkbox input {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
        }

    .fs-hours-input {
        width: 150px;
        box-sizing: border-box;
        background: #F1ECE6;
        border: 1px solid transparent;
        border-radius: 8px;
        padding: 5px 8px;
        font-size: 12px;
        color: #2E2B3D;
        font-family: inherit;
        outline: none;
        text-align: right;
        transition: border-color .15s ease, background .15s ease;
    }

        .fs-hours-input:focus {
            background: #FFFFFF;
            border-color: #F2A7BD;
        }

    .fs-hours-time {
        color: #B98A4D;
        font-weight: 600;
    }

    .fs-notif-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

        .fs-notif-list li {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 13px;
        }

    .fs-toggle {
        position: relative;
        display: inline-block;
        width: 38px;
        height: 22px;
        flex-shrink: 0;
    }

        .fs-toggle input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .fs-toggle-slider {
        position: absolute;
        inset: 0;
        background: #E5E0D9;
        border-radius: 22px;
        cursor: pointer;
        transition: background .15s ease;
    }

        .fs-toggle-slider::before {
            content: "";
            position: absolute;
            width: 16px;
            height: 16px;
            left: 3px;
            top: 3px;
            background: #FFFFFF;
            border-radius: 50%;
            transition: transform .15s ease;
        }

    .fs-toggle input:checked + .fs-toggle-slider {
        background: #F2A0B5;
    }

        .fs-toggle input:checked + .fs-toggle-slider::before {
            transform: translateX(16px);
        }

    @@media (max-width: 900px) {
        .fs-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
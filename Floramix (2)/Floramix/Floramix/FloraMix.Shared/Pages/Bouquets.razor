@page "/bouquets"
@inject IShopService ShopService

<div class="products-page">

    <div class="products-header">
        <div>
            <h1>Products</h1>
            <div class="products-subtitle">@(shop?.Name ?? "Shop") · Shop Portal</div>
        </div>
    </div>

    @if (bouquets is null)
    {
        <p>Loading...</p>
    }
    else
    {
        <div class="products-toolbar">
            <div class="products-count">@bouquets.Count products</div>
            <button class="btn-add-product" @onclick="StartNew">+ Add Product</button>
        </div>

        <div class="products-layout">

            <div class="products-main-col">
                @if (bouquets.Count == 0)
                {
                    <p>No products yet — add your first one above.</p>
                }
                else
                {
                    <div class="products-grid @(editing is not null ? "products-grid-narrow" : "")">
                        @foreach (var b in bouquets)
                        {
                            <div class="product-card" @key="b.Id">
                                <div class="product-image">
                                    @if (!string.IsNullOrWhiteSpace(b.ImageUrl))
                                    {
                                        <img src="@b.ImageUrl" alt="@b.Name" />
                                    }
                                    else
                                    {
                                        <div class="product-image-fallback @CategoryGradientClass(b.Category)">💐</div>
                                    }
                                    <span class="status-tag @StatusClass(b.Status)">@StatusLabel(b.Status)</span>
                                    <div class="product-hover-actions">
                                        <button class="round-icon-btn" title="Preview">👁</button>
                                        <button class="round-icon-btn" title="Edit" @onclick="() => Edit(b)">✏️</button>
                                    </div>
                                </div>

                                <div class="product-info">
                                    <div class="product-top-row">
                                        <div>
                                            <div class="product-name">@b.Name</div>
                                            <div class="product-category">@b.Category</div>
                                        </div>
                                        <div class="product-price">₱@b.Price.ToString("0")</div>
                                    </div>

                                    <div class="product-meta">
                                        <span class="meta-rating">⭐ @b.Rating.ToString("0.0")</span>
                                        <span class="meta-dot">·</span>
                                        <span>@b.SoldCount sold</span>
                                        <span class="meta-dot">·</span>
                                        <span class="@(b.StockCount == 0 ? "meta-stock out" : "meta-stock")">@b.StockCount in stock</span>
                                    </div>

                                    <div class="product-actions-row">
                                        <button class="link-btn" @onclick="() => Edit(b)">Edit</button>
                                        <button class="link-btn danger" @onclick="() => Delete(b)">Delete</button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            @if (editing is not null)
            {
                <div class="products-form-col">
                    <div class="product-form-card">
                        <div class="form-card-header">
                            <h5>@(editing.Id == 0 ? "New Product" : "Edit Product")</h5>
                            <button class="form-close-btn" title="Close" @onclick="() => editing = null">✕</button>
                        </div>

                        <div class="form-section">
                            <div class="form-row">
                                <label>Name</label>
                                <input class="form-control" @bind="editing.Name" placeholder="e.g. Sunflower Bouquet" />
                            </div>

                            <div class="form-row">
                                <label>Description</label>
                                <textarea class="form-control" rows="3" @bind="editing.Description" placeholder="Short description of the arrangement..."></textarea>
                            </div>
                        </div>

                        <div class="form-section">
                            <div class="form-row-group">
                                <div class="form-row">
                                    <label>Price (₱)</label>
                                    <input type="number" step="0.01" class="form-control" @bind="editing.Price" />
                                </div>
                                <div class="form-row">
                                    <label>Stock Count</label>
                                    <input type="number" class="form-control" @bind="editing.StockCount" />
                                </div>
                            </div>

                            <div class="form-row-group">
                                <div class="form-row">
                                    <label>Category</label>
                                    <select class="form-control" @bind="editing.Category">
                                        @foreach (var occ in Enum.GetValues<Occasion>())
                                        {
                                            <option value="@occ">@occ</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-row">
                                    <label>Status</label>
                                    <select class="form-control" @bind="editing.Status">
                                        @foreach (var status in Enum.GetValues<ProductStatus>())
                                        {
                                            <option value="@status">@StatusLabel(status)</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="form-row-group">
                                <div class="form-row">
                                    <label>Rating</label>
                                    <input type="number" step="0.1" min="0" max="5" class="form-control" @bind="editing.Rating" />
                                </div>
                                <div class="form-row">
                                    <label>Sold Count</label>
                                    <input type="number" class="form-control" @bind="editing.SoldCount" />
                                </div>
                            </div>
                        </div>

                        <div class="form-section">
                            <div class="form-row">
                                <label>Image URL</label>
                                <input class="form-control" @bind="editing.ImageUrl" placeholder="/images/products/example.png" />
                            </div>

                            <div class="form-row checkbox-row">
                                <input type="checkbox" @bind="editing.IsAvailable" id="avail" />
                                <label for="avail">Available for purchase</label>
                            </div>
                        </div>

                        <div class="form-actions">
                            <button class="btn-save" @onclick="Save">Save Product</button>
                            <button class="btn-cancel-form" @onclick="() => editing = null">Cancel</button>
                        </div>
                    </div>
                </div>
            }

        </div>
    }
</div>

@code {
    List<Bouquet>? bouquets;
    Shop? shop;
    Bouquet? editing;
    int shopId = 1; // TODO: replace with logged-in owner's shop

    protected override async Task OnInitializedAsync()
    {
        shop = await ShopService.GetShopAsync(shopId);
        await LoadBouquets();
    }

    async Task LoadBouquets()
    {
        bouquets = await ShopService.GetBouquetsAsync(shopId);
    }

    void StartNew()
    {
        editing = new Bouquet { ShopId = shopId };
    }

    void Edit(Bouquet bouquet)
    {
        editing = new Bouquet
        {
            Id = bouquet.Id,
            ShopId = bouquet.ShopId,
            Name = bouquet.Name,
            Description = bouquet.Description,
            Price = bouquet.Price,
            ImageUrl = bouquet.ImageUrl,
            IsAvailable = bouquet.IsAvailable,
            StockCount = bouquet.StockCount,
            Category = bouquet.Category,
            Rating = bouquet.Rating,
            SoldCount = bouquet.SoldCount,
            Status = bouquet.Status
        };
    }

    async Task Save()
    {
        if (editing is null) return;
        await ShopService.SaveBouquetAsync(editing);
        editing = null;
        await LoadBouquets();
    }

    async Task Delete(Bouquet bouquet)
    {
        await ShopService.DeleteBouquetAsync(bouquet.Id);
        await LoadBouquets();
    }

    string StatusLabel(ProductStatus status) => status switch
    {
        ProductStatus.Active => "Active",
        ProductStatus.LowStock => "Low Stock",
        ProductStatus.OutOfStock => "Out of Stock",
        _ => ""
    };

    string StatusClass(ProductStatus status) => status switch
    {
        ProductStatus.Active => "active",
        ProductStatus.LowStock => "low-stock",
        ProductStatus.OutOfStock => "out-of-stock",
        _ => ""
    };

    string CategoryGradientClass(Occasion category) => category switch
    {
        Occasion.Romance => "grad-romance",
        Occasion.Wedding => "grad-wedding",
        Occasion.Birthday => "grad-birthday",
        Occasion.Sympathy => "grad-sympathy",
        _ => "grad-other"
    };
}
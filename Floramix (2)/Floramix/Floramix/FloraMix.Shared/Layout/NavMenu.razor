@inject IShopService ShopService
@inject ShopStateService ShopState
@implements IDisposable

<div class="brand-row">
    <div class="brand-mark">🌸</div>
    <div>
        <div class="brand-name">FloraMix</div>
        <div class="brand-sub">Shop Portal</div>
    </div>
</div>

@if (shop is not null)
{
    <div class="shop-card">
        <div class="shop-avatar">@Initials(shop.Name)</div>
        <div class="shop-info">
            <div class="shop-name">@shop.Name</div>
            <div class="shop-location">@shop.Address</div>
        </div>
        <span class="shop-online-dot"></span>
    </div>
}

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="3" y="3" width="7.5" height="7.5" rx="2" fill="currentColor" />
                        <rect x="13.5" y="3" width="7.5" height="7.5" rx="2" fill="currentColor" />
                        <rect x="3" y="13.5" width="7.5" height="7.5" rx="2" fill="currentColor" />
                        <rect x="13.5" y="13.5" width="7.5" height="7.5" rx="2" fill="currentColor" />
                    </svg>
                </span>
                Overview
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="orders">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M6 8V6a6 6 0 1 1 12 0v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                        <rect x="3.5" y="8" width="17" height="13" rx="2.5" stroke="currentColor" stroke-width="1.8" />
                    </svg>
                </span>
                Orders
                @if (pendingCount > 0)
                {
                    <span class="nav-badge">@pendingCount</span>
                }
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="bouquets">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 3 3 7.5 12 12l9-4.5L12 3Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
                        <path d="M3 7.5V16.5L12 21V12" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
                        <path d="M21 7.5V16.5L12 21" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
                    </svg>
                </span>
                Products
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="messages">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M4 4h16v13H7l-3 3V4Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
                    </svg>
                </span>
                Messages
                @if (unreadCount > 0)
                {
                    <span class="nav-badge">@unreadCount</span>
                }
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="shop-settings">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="12" cy="12" r="3.2" stroke="currentColor" stroke-width="1.8" />
                        <path d="M19.4 13.5a1.7 1.7 0 0 0 .34 1.87l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.7 1.7 0 0 0-1.87-.34 1.7 1.7 0 0 0-1.04 1.56V19.5a2 2 0 1 1-4 0v-.09a1.7 1.7 0 0 0-1.04-1.56 1.7 1.7 0 0 0-1.87.34l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.7 1.7 0 0 0 .34-1.87 1.7 1.7 0 0 0-1.56-1.04H4.5a2 2 0 1 1 0-4h.09A1.7 1.7 0 0 0 6.15 6.5a1.7 1.7 0 0 0-.34-1.87l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.7 1.7 0 0 0 1.87.34H10.6A1.7 1.7 0 0 0 11.64 0.6V0.5a2 2 0 1 1 4 0v.09a1.7 1.7 0 0 0 1.04 1.56 1.7 1.7 0 0 0 1.87-.34l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.7 1.7 0 0 0-.34 1.87v0.09a1.7 1.7 0 0 0 1.56 1.04H19.5a2 2 0 1 1 0 4h-.09a1.7 1.7 0 0 0-1.56 1.04Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                    </svg>
                </span>
                Settings
            </NavLink>
        </div>
    </nav>
</div>

@code {
    Shop? shop;
    int pendingCount;
    int unreadCount;
    int shopId = 1; // TODO: replace with logged-in owner's shop

    protected override async Task OnInitializedAsync()
    {
        ShopState.OnShopChanged += HandleShopChanged;
        await RefreshAsync();
    }

    async Task RefreshAsync()
    {
        shop = await ShopService.GetShopAsync(shopId);
        var orders = await ShopService.GetOrdersAsync(shopId);
        pendingCount = orders.Count(o => o.Status == OrderStatus.Pending && !o.IsArchived);
        unreadCount = await ShopService.GetUnreadMessageCountAsync(shopId);
    }

    async void HandleShopChanged()
    {
        await RefreshAsync();
        await InvokeAsync(StateHasChanged);
    }

    string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        var letters = parts.Take(2).Select(p => p[0]);
        return new string(letters.ToArray()).ToUpper();
    }

    public void Dispose()
    {
        ShopState.OnShopChanged -= HandleShopChanged;
    }
}
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FloraMix.Views.Main.SettingsPage"
             BackgroundColor="{StaticResource FloraCream}">
    <Grid>
        <ScrollView VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Spacing="20" Padding="24,56,24,24">

                <Grid ColumnDefinitions="Auto,*">
                    <Border Grid.Column="0" HeightRequest="36" WidthRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="0" BackgroundColor="{StaticResource FloraFieldBg}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped" />
                        </Border.GestureRecognizers>
                        <Label Text="&#xE76B;" FontFamily="Segoe Fluent Icons" FontSize="16" TextColor="{StaticResource FloraCharcoal}" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <Label Grid.Column="1" Text="Settings" FontFamily="Serif" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource FloraCharcoal}" Margin="12,0,0,0" VerticalOptions="Center" />
                </Grid>

                <Label Text="ACCOUNT" FontSize="11" FontAttributes="Bold" CharacterSpacing="1" TextColor="{StaticResource FloraBlush}" />

                <VerticalStackLayout Spacing="0">
                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 16,16,0,0" Padding="16" StrokeThickness="0">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" HeightRequest="44" WidthRequest="44" StrokeShape="RoundRectangle 22" StrokeThickness="0" BackgroundColor="{StaticResource FloraBlush}">
                                <Label x:Name="AvatarInitialLabel" Text="E" FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="12,0,0,0" VerticalOptions="Center">
                                <Label x:Name="AccountNameLabel" Text="Emma Rose" FontAttributes="Bold" FontSize="15" TextColor="{StaticResource FloraCharcoal}" />
                                <Label x:Name="AccountEmailLabel" Text="emma.rose@example.com" FontSize="12" TextColor="{StaticResource FloraBlush}" />
                                <Label x:Name="AccountPhoneLabel" Text="+44 7700 900123" FontSize="12" TextColor="{StaticResource FloraBlush}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="&#xE70F;" FontFamily="Segoe Fluent Icons" FontSize="15" TextColor="{StaticResource FloraBlush}" VerticalOptions="Start">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnEditProfileTapped" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </Border>
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource FloraFieldBg}" />
                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 0,0,16,16" Padding="16" StrokeThickness="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnChangePasswordTapped" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" HeightRequest="36" WidthRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="0" BackgroundColor="{StaticResource FloraFieldBg}">
                                <Label Text="&#xE72E;" FontFamily="Segoe Fluent Icons" FontSize="14" TextColor="{StaticResource FloraCharcoal}" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1" Text="Change Password" FontSize="14" TextColor="{StaticResource FloraCharcoal}" Margin="12,0,0,0" VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="&#xE76C;" FontFamily="Segoe Fluent Icons" FontSize="12" TextColor="{StaticResource FloraMuted}" VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <Label Text="PREFERENCES" FontSize="11" FontAttributes="Bold" CharacterSpacing="1" TextColor="{StaticResource FloraBlush}" />

                <VerticalStackLayout Spacing="0">
                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 16,16,0,0" Padding="16" StrokeThickness="0">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" HeightRequest="36" WidthRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="0" BackgroundColor="{StaticResource FloraFieldBg}">
                                <Label Text="&#xE708;" FontFamily="Segoe Fluent Icons" FontSize="14" TextColor="{StaticResource FloraCharcoal}" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1" Text="Dark Mode" FontSize="14" TextColor="{StaticResource FloraCharcoal}" Margin="12,0,0,0" VerticalOptions="Center" />
                            <Switch Grid.Column="2" x:Name="DarkModeSwitch" OnColor="{StaticResource FloraBlush}" ThumbColor="White" Toggled="OnDarkModeToggled" HorizontalOptions="End" VerticalOptions="Center" Margin="0,0,-110,0" />
                        </Grid>
                    </Border>
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource FloraFieldBg}" />
                    <Border BackgroundColor="White" Padding="16" StrokeThickness="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLanguageTapped" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" HeightRequest="36" WidthRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="0" BackgroundColor="{StaticResource FloraFieldBg}">
                                <Label Text="&#xE774;" FontFamily="Segoe Fluent Icons" FontSize="14" TextColor="{StaticResource FloraCharcoal}" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1" Text="Language" FontSize="14" TextColor="{StaticResource FloraCharcoal}" Margin="12,0,0,0" VerticalOptions="Center" />
                            <HorizontalStackLayout Grid.Column="2" Spacing="6" VerticalOptions="Center">
                                <Label x:Name="LanguageValueLabel" Text="English" FontSize="13" TextColor="{StaticResource FloraMuted}" />
                                <Label Text="&#xE70D;" FontFamily="Segoe Fluent Icons" FontSize="11" TextColor="{StaticResource FloraMuted}" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource FloraFieldBg}" />
                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 0,0,16,16" Padding="16" StrokeThickness="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCurrencyTapped" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" HeightRequest="36" WidthRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="0" BackgroundColor="{StaticResource FloraFieldBg}">
                                <Label Text="&#163;" FontSize="15" TextColor="{StaticResource FloraCharcoal}" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1" Text="Currency" FontSize="14" TextColor="{StaticResource FloraCharcoal}" Margin="12,0,0,0" VerticalOptions="Center" />
                            <HorizontalStackLayout Grid.Column="2" Spacing="6" VerticalOptions="Center">
                                <Label x:Name="CurrencyValueLabel" Text="GBP &#163;" FontSize="13" TextColor="{StaticResource FloraMuted}" />
                                <Label Text="&#xE70D;" FontFamily="Segoe Fluent Icons" FontSize="11" TextColor="{StaticResource FloraMuted}" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <Label Text="SECURITY" FontSize="11" FontAttributes="Bold" CharacterSpacing="1" TextColor="{StaticResource FloraBlush}" />

                <VerticalStackLayout Spacing="0">
                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 16,16,0,0" Padding="16" StrokeThickness="0">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" HeightRequest="36" WidthRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="0" BackgroundColor="{StaticResource FloraFieldBg}">
                                <Label Text="&#xE8EA;" FontFamily="Segoe Fluent Icons" FontSize="14" TextColor="{StaticResource FloraCharcoal}" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1" Text="Face ID / Touch ID" FontSize="14" TextColor="{StaticResource FloraCharcoal}" Margin="12,0,0,0" VerticalOptions="Center" />
                            <Switch Grid.Column="2" x:Name="FaceIdSwitch" OnColor="{StaticResource FloraBlush}" ThumbColor="White" Toggled="OnFaceIdToggled" HorizontalOptions="End" VerticalOptions="Center" Margin="0,0,-110,0" />
                        </Grid>
                    </Border>
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource FloraFieldBg}" />
                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 0,0,16,16" Padding="16" StrokeThickness="0">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" HeightRequest="36" WidthRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="0" BackgroundColor="{StaticResource FloraFieldBg}">
                                <Label Text="&#xE730;" FontFamily="Segoe Fluent Icons" FontSize="14" TextColor="{StaticResource FloraCharcoal}" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1" Text="Two-Factor Authentication" FontSize="14" TextColor="{StaticResource FloraCharcoal}" Margin="12,0,0,0" VerticalOptions="Center" />
                            <Switch Grid.Column="2" x:Name="TwoFactorSwitch" OnColor="{StaticResource FloraBlush}" ThumbColor="White" Toggled="OnTwoFactorToggled" HorizontalOptions="End" VerticalOptions="Center" Margin="0,0,-110,0" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <Label Text="ABOUT" FontSize="11" FontAttributes="Bold" CharacterSpacing="1" TextColor="{StaticResource FloraBlush}" />

                <Border BackgroundColor="White" StrokeShape="RoundRectangle 16" Padding="16" StrokeThickness="0">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0" HeightRequest="36" WidthRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="0" BackgroundColor="{StaticResource FloraFieldBg}">
                            <Label Text="&#xE946;" FontFamily="Segoe Fluent Icons" FontSize="14" TextColor="{StaticResource FloraCharcoal}" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Grid.Column="1" Text="App Version" FontSize="14" TextColor="{StaticResource FloraCharcoal}" Margin="12,0,0,0" VerticalOptions="Center" />
                        <Label x:Name="AppVersionLabel" Grid.Column="2" Text="v2.4.1" FontSize="13" TextColor="{StaticResource FloraMuted}" VerticalOptions="Center" />
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <Grid x:Name="PasswordOverlay" BackgroundColor="#66000000" IsVisible="False">
            <Border BackgroundColor="{StaticResource FloraCream}" StrokeShape="RoundRectangle 20" StrokeThickness="0" Padding="24" WidthRequest="340" HorizontalOptions="Center" VerticalOptions="Center">
                <VerticalStackLayout Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Change Password" FontFamily="Serif" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource FloraCharcoal}" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="&#xE711;" FontFamily="Segoe Fluent Icons" FontSize="16" TextColor="{StaticResource FloraMuted}" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnClosePasswordOverlay" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Current Password" FontSize="13" TextColor="{StaticResource FloraCharcoal}" />
                        <Border BackgroundColor="{StaticResource FloraFieldBg}" StrokeShape="RoundRectangle 14" StrokeThickness="0">
                            <Entry x:Name="CurrentPasswordEntry" IsPassword="True" BackgroundColor="Transparent" Margin="8,0" TextColor="{StaticResource FloraCharcoal}" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="New Password" FontSize="13" TextColor="{StaticResource FloraCharcoal}" />
                        <Border BackgroundColor="{StaticResource FloraFieldBg}" StrokeShape="RoundRectangle 14" StrokeThickness="0">
                            <Entry x:Name="NewPasswordEntry" IsPassword="True" BackgroundColor="Transparent" Margin="8,0" TextColor="{StaticResource FloraCharcoal}" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Confirm New Password" FontSize="13" TextColor="{StaticResource FloraCharcoal}" />
                        <Border BackgroundColor="{StaticResource FloraFieldBg}" StrokeShape="RoundRectangle 14" StrokeThickness="0">
                            <Entry x:Name="ConfirmPasswordEntry" IsPassword="True" BackgroundColor="Transparent" Margin="8,0" TextColor="{StaticResource FloraCharcoal}" />
                        </Border>
                    </VerticalStackLayout>

                    <Border BackgroundColor="{StaticResource FloraBlush}" StrokeShape="RoundRectangle 24" HeightRequest="50" StrokeThickness="0" Margin="0,6,0,0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnUpdatePasswordTapped" />
                        </Border.GestureRecognizers>
                        <Label Text="Update Password" FontAttributes="Bold" FontSize="15" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
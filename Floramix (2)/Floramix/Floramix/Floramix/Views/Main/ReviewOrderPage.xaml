<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FloraMix.Views.Main.ReviewOrderPage"
             BackgroundColor="{StaticResource FloraCream}">
    <ScrollView VerticalScrollBarVisibility="Never">
        <VerticalStackLayout Padding="24,56,24,24" Spacing="20">

            <Grid ColumnDefinitions="Auto,*">
                <Label Grid.Column="0" Text="&#xE72B;" FontFamily="Segoe Fluent Icons" FontSize="18" TextColor="{StaticResource FloraCharcoal}" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Label.GestureRecognizers>
                </Label>
                <Label Grid.Column="1" Text="Review Order" FontFamily="Serif" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource FloraCharcoal}" Margin="12,0,0,0" VerticalOptions="Center" />
            </Grid>

            <Grid x:Name="StepIndicatorGrid" ColumnDefinitions="*,*,*,*" />

            <Border BackgroundColor="White" StrokeShape="RoundRectangle 16" Padding="16" StrokeThickness="0">
                <VerticalStackLayout Spacing="10">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="&#xE7B8;" FontFamily="Segoe Fluent Icons" FontSize="14" TextColor="{StaticResource FloraCharcoal}" />
                        <Label Text="Order Items" FontAttributes="Bold" FontSize="15" TextColor="{StaticResource FloraCharcoal}" />
                    </HorizontalStackLayout>
                    <VerticalStackLayout x:Name="OrderItemsStack" Spacing="10" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White" StrokeShape="RoundRectangle 16" Padding="16" StrokeThickness="0">
                <VerticalStackLayout Spacing="12">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="&#xE7C3;" FontFamily="Segoe Fluent Icons" FontSize="14" TextColor="{StaticResource FloraCharcoal}" />
                        <Label Text="Delivery Details" FontAttributes="Bold" FontSize="15" TextColor="{StaticResource FloraCharcoal}" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="&#xE81D;" FontFamily="Segoe Fluent Icons" FontSize="13" TextColor="{StaticResource FloraBlush}" />
                        <VerticalStackLayout Spacing="2">
                            <Label x:Name="DeliveryAddressLabelLabel" Text="Home" FontAttributes="Bold" FontSize="13" TextColor="{StaticResource FloraBlush}" />
                            <Label x:Name="DeliveryAddressLineLabel" Text="12 Kensington Gardens Square, London, W2 4BH" FontSize="12" TextColor="{StaticResource FloraMuted}" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="&#xE823;" FontFamily="Segoe Fluent Icons" FontSize="13" TextColor="{StaticResource FloraBlush}" />
                        <VerticalStackLayout Spacing="2">
                            <Label x:Name="DeliveryDateLabel" Text="Today" FontAttributes="Bold" FontSize="13" TextColor="{StaticResource FloraBlush}" />
                            <Label x:Name="DeliveryTimeLabel" Text="1:00 - 3:00 PM" FontSize="12" TextColor="{StaticResource FloraMuted}" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout x:Name="DeliveryNoteRow" Spacing="8" IsVisible="False">
                        <Label Text="&#xE70B;" FontFamily="Segoe Fluent Icons" FontSize="13" TextColor="{StaticResource FloraBlush}" />
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Delivery Note" FontAttributes="Bold" FontSize="13" TextColor="{StaticResource FloraBlush}" />
                            <Label x:Name="DeliveryNoteLabel" Text="" FontSize="12" TextColor="{StaticResource FloraMuted}" LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White" StrokeShape="RoundRectangle 16" Padding="16" StrokeThickness="0">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0" HeightRequest="30" WidthRequest="44" StrokeShape="RoundRectangle 6" StrokeThickness="0" BackgroundColor="{StaticResource FloraBlush}" />
                    <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="12,0,0,0">
                        <Label x:Name="PaymentCardLabel" Text="VISA &#8226;&#8226;&#8226;&#8226; 4291" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource FloraCharcoal}" />
                        <Label x:Name="PaymentExpiryLabel" Text="Expires 09/28" FontSize="12" TextColor="{StaticResource FloraMuted}" />
                    </VerticalStackLayout>
                    <Label Grid.Column="2" Text="&#xE8C7;" FontFamily="Segoe Fluent Icons" FontSize="16" TextColor="{StaticResource FloraMuted}" VerticalOptions="Center" />
                </Grid>
            </Border>

            <Border BackgroundColor="White" StrokeShape="RoundRectangle 16" Padding="16" StrokeThickness="0">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Subtotal" FontSize="14" TextColor="{StaticResource FloraCharcoal}" />
                        <Label Grid.Column="1" x:Name="ReviewSubtotalLabel" Text="₱3,449" FontSize="14" TextColor="{StaticResource FloraCharcoal}" HorizontalOptions="End" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Delivery" FontSize="14" TextColor="{StaticResource FloraCharcoal}" />
                        <Label Grid.Column="1" x:Name="ReviewDeliveryLabel" Text="₱100" FontSize="14" TextColor="{StaticResource FloraCharcoal}" HorizontalOptions="End" />
                    </Grid>
                    <Grid x:Name="ReviewDiscountRow" ColumnDefinitions="*,Auto" IsVisible="False">
                        <Label Text="Discount" FontSize="14" TextColor="#5B8C5A" />
                        <Label Grid.Column="1" x:Name="ReviewDiscountLabel" Text="-₱0" FontSize="14" TextColor="#5B8C5A" HorizontalOptions="End" />
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource FloraFieldBg}" />
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Total charged" FontAttributes="Bold" FontSize="18" TextColor="{StaticResource FloraCharcoal}" />
                        <Label Grid.Column="1" x:Name="ReviewTotalLabel" Text="₱3,549" FontAttributes="Bold" FontSize="18" TextColor="{StaticResource FloraCharcoal}" HorizontalOptions="End" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Label Text="By placing this order you agree to our Terms of Service and Privacy Policy. Your payment will be processed securely."
                   FontSize="11" TextColor="{StaticResource FloraMuted}" LineBreakMode="WordWrap" />

            <Border BackgroundColor="{StaticResource FloraBlush}" StrokeShape="RoundRectangle 24" HeightRequest="54">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPlaceOrderTapped" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                    <Label x:Name="PlaceOrderLabel" Text="Place Order - $134.50" FontAttributes="Bold" FontSize="16" TextColor="White" />
                </HorizontalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
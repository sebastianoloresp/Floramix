<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FloraMix.Views.Main.ProfilePage"
             BackgroundColor="{StaticResource FloraCream}">
    <ScrollView VerticalScrollBarVisibility="Never">
        <VerticalStackLayout Spacing="0">

            <Grid Padding="24,56,24,20" BackgroundColor="{StaticResource FloraFieldBg}" ColumnDefinitions="*,Auto">
                <Label Grid.Column="0" Text="My Profile" FontSize="15" TextColor="{StaticResource FloraMuted}" VerticalOptions="Center" />
                <Label Grid.Column="1" Text="&#xE713;" FontFamily="Segoe Fluent Icons" FontSize="18" TextColor="{StaticResource FloraCharcoal}" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSettingsTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

            <VerticalStackLayout Padding="24,20,24,24" Spacing="20" BackgroundColor="{StaticResource FloraFieldBg}">

                <Grid ColumnDefinitions="Auto,*">
                    <Border Grid.Column="0" HeightRequest="64" WidthRequest="64" StrokeShape="RoundRectangle 32" StrokeThickness="0" BackgroundColor="{StaticResource FloraBlush}">
                        <Label Text="&#xE77B;" FontFamily="Segoe Fluent Icons" FontSize="26" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="14,0,0,0" VerticalOptions="Center">
                        <Label x:Name="ProfileNameLabel" Text="Emma Rose" FontFamily="Serif" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource FloraCharcoal}" />
                        <Label x:Name="ProfileEmailLabel" Text="emma.rose@example.com" FontSize="13" TextColor="{StaticResource FloraMuted}" />
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="&#xE81D;" FontFamily="Segoe Fluent Icons" FontSize="11" TextColor="{StaticResource FloraBlush}" />
                            <Label x:Name="ProfileLocationLabel" Text="London, UK" FontSize="12" TextColor="{StaticResource FloraBlush}" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Grid>

                <Grid ColumnDefinitions="*,*,*">
                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                        <Label x:Name="OrdersCountLabel" Text="4" FontAttributes="Bold" FontSize="20" TextColor="{StaticResource FloraCharcoal}" HorizontalOptions="Center" />
                        <Label Text="Orders" FontSize="12" TextColor="{StaticResource FloraMuted}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                        <Label x:Name="ReviewsCountLabel" Text="3" FontAttributes="Bold" FontSize="20" TextColor="{StaticResource FloraCharcoal}" HorizontalOptions="Center" />
                        <Label Text="Reviews" FontSize="12" TextColor="{StaticResource FloraMuted}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                        <Label x:Name="WishlistCountLabel" Text="6" FontAttributes="Bold" FontSize="20" TextColor="{StaticResource FloraCharcoal}" HorizontalOptions="Center" />
                        <Label Text="Wishlisted" FontSize="12" TextColor="{StaticResource FloraMuted}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Grid>

            </VerticalStackLayout>

            <VerticalStackLayout Padding="24,20,24,24" Spacing="16">

                <HorizontalStackLayout Spacing="8">
                    <Label Text="&#xE7B8;" FontFamily="Segoe Fluent Icons" FontSize="15" TextColor="{StaticResource FloraCharcoal}" VerticalOptions="Center" />
                    <Label Text="Order History" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource FloraCharcoal}" VerticalOptions="Center" />
                </HorizontalStackLayout>

                <VerticalStackLayout x:Name="OrderHistoryStack" Spacing="12" />

                <Label Text="Saved Addresses" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource FloraCharcoal}" Margin="0,12,0,0" />

                <VerticalStackLayout x:Name="AddressesStack" Spacing="12" />

                <Border BackgroundColor="{StaticResource FloraFieldBg}" StrokeShape="RoundRectangle 20" HeightRequest="48" StrokeThickness="0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAddAddressTapped" />
                    </Border.GestureRecognizers>
                    <Label Text="+ Add New Address" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource FloraCharcoal}" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>

                <VerticalStackLayout Spacing="0" Margin="0,12,0,0">
                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 16,16,0,0" Padding="16" StrokeThickness="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNotificationsTapped" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" BackgroundColor="{StaticResource FloraFieldBg}" HeightRequest="36" WidthRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="0">
                                <Label Text="&#xEA8F;" FontFamily="Segoe Fluent Icons" FontSize="14" TextColor="{StaticResource FloraCharcoal}" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1" Text="Notifications" FontSize="14" TextColor="{StaticResource FloraCharcoal}" Margin="12,0,0,0" VerticalOptions="Center" />
                            <HorizontalStackLayout Grid.Column="2" Spacing="6" VerticalOptions="Center">
                                <Label x:Name="NotificationsCountLabel" Text="3 new" FontSize="12" TextColor="{StaticResource FloraMuted}" />
                                <Label Text="&#xE76C;" FontFamily="Segoe Fluent Icons" FontSize="12" TextColor="{StaticResource FloraMuted}" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource FloraFieldBg}" />

                    <Border BackgroundColor="White" Padding="16" StrokeThickness="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPaymentMethodsTapped" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" BackgroundColor="{StaticResource FloraFieldBg}" HeightRequest="36" WidthRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="0">
                                <Label Text="&#xE8C7;" FontFamily="Segoe Fluent Icons" FontSize="14" TextColor="{StaticResource FloraCharcoal}" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1" Text="Payment Methods" FontSize="14" TextColor="{StaticResource FloraCharcoal}" Margin="12,0,0,0" VerticalOptions="Center" />
                            <HorizontalStackLayout Grid.Column="2" Spacing="6" VerticalOptions="Center">
                                <Label x:Name="PaymentMethodsCountLabel" Text="2 cards" FontSize="12" TextColor="{StaticResource FloraMuted}" />
                                <Label Text="&#xE76C;" FontFamily="Segoe Fluent Icons" FontSize="12" TextColor="{StaticResource FloraMuted}" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource FloraFieldBg}" />

                    <Border BackgroundColor="White" Padding="16" StrokeThickness="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSavedAddressesTapped" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" BackgroundColor="{StaticResource FloraFieldBg}" HeightRequest="36" WidthRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="0">
                                <Label Text="&#xE81D;" FontFamily="Segoe Fluent Icons" FontSize="14" TextColor="{StaticResource FloraCharcoal}" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1" Text="Saved Addresses" FontSize="14" TextColor="{StaticResource FloraCharcoal}" Margin="12,0,0,0" VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="&#xE76C;" FontFamily="Segoe Fluent Icons" FontSize="12" TextColor="{StaticResource FloraMuted}" VerticalOptions="Center" />
                        </Grid>
                    </Border>
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource FloraFieldBg}" />

                    <Border BackgroundColor="White" Padding="16" StrokeThickness="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnWishlistTapped" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" BackgroundColor="{StaticResource FloraFieldBg}" HeightRequest="36" WidthRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="0">
                                <Label Text="&#xEB51;" FontFamily="Segoe Fluent Icons" FontSize="14" TextColor="{StaticResource FloraCharcoal}" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1" Text="Wishlist" FontSize="14" TextColor="{StaticResource FloraCharcoal}" Margin="12,0,0,0" VerticalOptions="Center" />
                            <HorizontalStackLayout Grid.Column="2" Spacing="6" VerticalOptions="Center">
                                <Label x:Name="WishlistItemsCountLabel" Text="6 items" FontSize="12" TextColor="{StaticResource FloraMuted}" />
                                <Label Text="&#xE76C;" FontFamily="Segoe Fluent Icons" FontSize="12" TextColor="{StaticResource FloraMuted}" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource FloraFieldBg}" />

                    <Border BackgroundColor="White" Padding="16" StrokeThickness="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSettingsTapped" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" BackgroundColor="{StaticResource FloraFieldBg}" HeightRequest="36" WidthRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="0">
                                <Label Text="&#xE713;" FontFamily="Segoe Fluent Icons" FontSize="14" TextColor="{StaticResource FloraCharcoal}" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1" Text="Settings" FontSize="14" TextColor="{StaticResource FloraCharcoal}" Margin="12,0,0,0" VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="&#xE76C;" FontFamily="Segoe Fluent Icons" FontSize="12" TextColor="{StaticResource FloraMuted}" VerticalOptions="Center" />
                        </Grid>
                    </Border>
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource FloraFieldBg}" />

                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 0,0,16,16" Padding="16" StrokeThickness="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnHelpSupportTapped" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" BackgroundColor="{StaticResource FloraFieldBg}" HeightRequest="36" WidthRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="0">
                                <Label Text="&#xE897;" FontFamily="Segoe Fluent Icons" FontSize="14" TextColor="{StaticResource FloraCharcoal}" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1" Text="Help &amp; Support" FontSize="14" TextColor="{StaticResource FloraCharcoal}" Margin="12,0,0,0" VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="&#xE76C;" FontFamily="Segoe Fluent Icons" FontSize="12" TextColor="{StaticResource FloraMuted}" VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <Label Text="Sign Out"
                       TextColor="#D9534F"
                       FontAttributes="Bold"
                       FontSize="14"
                       HorizontalOptions="Center"
                       Margin="0,20,0,20">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSignOutTapped" />
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
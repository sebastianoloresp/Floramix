<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FloraMix.Views.Onboarding.RoleSelectionPage"
             BackgroundColor="{StaticResource FloraCream}"
             Shell.NavBarIsVisible="False">

    <VerticalStackLayout Padding="24,52,24,24" Spacing="14">

        <Image Source="back_arrow.png" WidthRequest="22" HeightRequest="22" HorizontalOptions="Start">
            <Image.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackTapped" />
            </Image.GestureRecognizers>
        </Image>

        <Label Text="Welcome" TextColor="{StaticResource FloraBlush}" FontAttributes="Bold" FontSize="14" Margin="0,20,0,0" />
        <Label FontFamily="PlayfairRegular" FontSize="28" TextColor="{StaticResource FloraCharcoal}"
               Text="How will you use FloraMix?" Margin="0,0,0,10" />

        <Frame BackgroundColor="White" CornerRadius="20" Padding="18" HasShadow="False" BorderColor="Transparent">
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCustomerTapped" />
            </Frame.GestureRecognizers>
            <HorizontalStackLayout Spacing="14">
                <Frame BackgroundColor="#FBE6EA" CornerRadius="14" WidthRequest="52" HeightRequest="52" Padding="0" HasShadow="False">
                    <Image Source="customer_role_icon.png" WidthRequest="26" HeightRequest="26"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Frame>
                <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                    <Label Text="I'm a Customer" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource FloraCharcoal}" />
                    <Label Text="Browse arrangements, build bouquets, and track your deliveries."
                           FontSize="12" TextColor="{StaticResource FloraMuted}" LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Frame>

        <Frame BackgroundColor="White" CornerRadius="20" Padding="18" HasShadow="False" BorderColor="Transparent">
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnOwnerTapped" />
            </Frame.GestureRecognizers>
            <HorizontalStackLayout Spacing="14">
                <Frame BackgroundColor="#E7F0E4" CornerRadius="14" WidthRequest="52" HeightRequest="52" Padding="0" HasShadow="False">
                    <Image Source="shop_role_icon.png" WidthRequest="26" HeightRequest="26"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Frame>
                <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                    <Label Text="I'm a Shop Owner" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource FloraCharcoal}" />
                    <Label Text="Manage your shop, process orders, and grow your business."
                           FontSize="12" TextColor="{StaticResource FloraMuted}" LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Frame>

    </VerticalStackLayout>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FloraMix.Views.Auth.AuthPage"
             BackgroundColor="{StaticResource FloraCream}"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="24,52,24,24" Spacing="12">

            <Image Source="back_arrow.png" WidthRequest="22" HeightRequest="22" HorizontalOptions="Start">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Image.GestureRecognizers>
            </Image>

            <HorizontalStackLayout Spacing="6" Margin="0,20,0,0">
                <Label Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="16" TextColor="{StaticResource FloraBlush}" VerticalOptions="Center" />
                <Label x:Name="RoleLabel" TextColor="{StaticResource FloraBlush}" FontAttributes="Bold" FontSize="14" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <Label FontFamily="PlayfairRegular" FontSize="28" TextColor="{StaticResource FloraCharcoal}" Text="Welcome back" />
            <Label Text="Sign in to continue to FloraMix" FontSize="14" TextColor="{StaticResource FloraMuted}" Margin="0,0,0,6" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" BackgroundColor="{StaticResource FloraFieldBg}" Padding="4" HeightRequest="46">
                <Grid.Resources>
                    <Style TargetType="Frame">
                        <Setter Property="CornerRadius" Value="12" />
                        <Setter Property="HasShadow" Value="False" />
                        <Setter Property="Padding" Value="0" />
                    </Style>
                </Grid.Resources>
                <Frame x:Name="SignInTabFrame" Grid.Column="0" BackgroundColor="White">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSignInTabTapped" />
                    </Frame.GestureRecognizers>
                    <Label x:Name="SignInTabLabel" Text="Sign In" HorizontalOptions="Center" VerticalOptions="Center"
                           FontAttributes="Bold" TextColor="{StaticResource FloraCharcoal}" />
                </Frame>
                <Frame x:Name="SignUpTabFrame" Grid.Column="1" BackgroundColor="Transparent">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSignUpTabTapped" />
                    </Frame.GestureRecognizers>
                    <Label x:Name="SignUpTabLabel" Text="Sign Up" HorizontalOptions="Center" VerticalOptions="Center"
                           FontAttributes="Bold" TextColor="{StaticResource FloraMuted}" />
                </Frame>
            </Grid>

            <Label x:Name="NameLabel" Text="Full Name" FontAttributes="Bold" FontSize="13" TextColor="{StaticResource FloraCharcoal}" Margin="0,10,0,0" IsVisible="False" />
            <Frame x:Name="NameFrame" BackgroundColor="{StaticResource FloraFieldBg}" CornerRadius="14" Padding="16,0"
                   HeightRequest="50" HasShadow="False" IsVisible="False">
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <Label Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="16" TextColor="{StaticResource FloraBlush}" VerticalOptions="Center" />
                    <Entry x:Name="NameEntry" Placeholder="Emma Watson" TextColor="{StaticResource FloraCharcoal}"
                           PlaceholderColor="{StaticResource FloraMuted}" BackgroundColor="Transparent"
                           VerticalOptions="Center" HorizontalOptions="FillAndExpand" />
                </HorizontalStackLayout>
            </Frame>

            <Label Text="Email" FontAttributes="Bold" FontSize="13" TextColor="{StaticResource FloraCharcoal}" Margin="0,10,0,0" />
            <Frame BackgroundColor="{StaticResource FloraFieldBg}" CornerRadius="14" Padding="16,0" HeightRequest="50" HasShadow="False">
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <Label Text="&#xE715;" FontFamily="Segoe MDL2 Assets" FontSize="16" TextColor="{StaticResource FloraBlush}" VerticalOptions="Center" />
                    <Entry x:Name="EmailEntry" Placeholder="emma@example.com" TextColor="{StaticResource FloraCharcoal}"
                           PlaceholderColor="{StaticResource FloraMuted}" BackgroundColor="Transparent"
                           VerticalOptions="Center" HorizontalOptions="FillAndExpand" />
                </HorizontalStackLayout>
            </Frame>

            <Label Text="Password" FontAttributes="Bold" FontSize="13" TextColor="{StaticResource FloraCharcoal}" />
            <Frame BackgroundColor="{StaticResource FloraFieldBg}" CornerRadius="14" Padding="16,0" HeightRequest="50" HasShadow="False">
                <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                    <Label Grid.Column="0" Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                           TextColor="{StaticResource FloraBlush}" VerticalOptions="Center" Margin="0,0,10,0" />
                    <Entry Grid.Column="1" x:Name="PasswordEntry" Placeholder="••••••••" IsPassword="True"
                           TextColor="{StaticResource FloraCharcoal}" PlaceholderColor="{StaticResource FloraMuted}"
                           BackgroundColor="Transparent" VerticalOptions="Center" />
                    <Label Grid.Column="2" x:Name="PasswordEyeIcon" Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                           TextColor="{StaticResource FloraMuted}" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTogglePasswordVisibility" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Frame>

            <Label x:Name="ForgotPasswordLabel" Text="Forgot password?" TextColor="{StaticResource FloraBlush}"
                   FontAttributes="Bold" FontSize="13" HorizontalOptions="End" Margin="0,2,0,0" />

            <Button x:Name="SubmitButton" Text="Sign In" BackgroundColor="{StaticResource FloraBlush}" TextColor="White"
                    CornerRadius="26" HeightRequest="52" FontAttributes="Bold" Margin="0,14,0,0"
                    Clicked="OnSignInClicked" />

            <Label Text="or continue with" TextColor="{StaticResource FloraMuted}" FontSize="13" HorizontalOptions="Center" Margin="0,4,0,0" />

            <Frame x:Name="GoogleSignInFrame" BackgroundColor="White" CornerRadius="26" HeightRequest="56" HasShadow="False"
                   BorderColor="{StaticResource FloraFieldBg}" Padding="16,0">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnGoogleSignInTapped" />
                </Frame.GestureRecognizers>
                <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                    <Image Source="google_icon.png" WidthRequest="20" HeightRequest="20" VerticalOptions="Center" />
                    <Label x:Name="GoogleSignInLabel" Text="Continue with Google" FontAttributes="Bold" TextColor="{StaticResource FloraCharcoal}"
                           FontSize="14" VerticalOptions="Center" LineBreakMode="NoWrap" />
                </HorizontalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>